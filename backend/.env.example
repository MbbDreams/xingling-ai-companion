APP_ENV=local
API_PREFIX=/api/v1

# Docker Compose defaults. Change these before using a shared environment.
DATABASE_URL=postgresql+asyncpg://xingling:xingling_dev@localhost:5433/xingling_ai
REDIS_URL=redis://localhost:6380/0

# AI service. Leave empty to run the local fallback reply path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Comma-separated origins for the static prototype / future Flutter web builds.
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
