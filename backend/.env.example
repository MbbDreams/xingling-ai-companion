APP_ENV=local
API_PREFIX=/api/v1

# Docker Compose defaults. Change these before using a shared environment.
DATABASE_URL=postgresql+asyncpg://xingling:xingling_dev@localhost:5433/xingling_ai
REDIS_URL=redis://localhost:6380/0

# DeepSeek API 配置（聊天模型）
# 从 https://platform.deepseek.com/api_keys 获取 API Key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Embedding 配置（豆包/火山引擎）
# 从 https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey 获取 API Key
EMBEDDING_API_KEY=your-volcengine-api-key
EMBEDDING_MODEL=doubao-embedding-text-240715

# 可选豆包模型:
# - doubao-embedding-text-240715 (1024维，推荐用于文本)
# - doubao-embedding-large-text-241215 (4096维，大文本)
# - doubao-embedding-vision-251215 (2048维，多模态)
# - doubao-embedding-vision-250615 (2048维，多模态，支持视频)
# - doubao-embedding-vision-250328 (2048维，多模态)
# - doubao-embedding-vision-241215 (3072维，多模态，不支持降维)

# Comma-separated origins for the static prototype / future Flutter web builds.
# 包含前端开发常用端口: 3000(React), 5000(Flutter), 5173(Vite), 8080, 4173
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:4173,http://127.0.0.1:4173

# JWT 配置
SECRET_KEY=your-secret-key-here-change-in-production

# 记忆系统配置
MEMORY_SUMMARY_THRESHOLD=12
MEMORY_KEEP_RECENT=6
MEMORY_MAX_RETRIEVE=5
